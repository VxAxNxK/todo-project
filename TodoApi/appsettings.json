{
  "ConnectionStrings": {
    "DefaultConnection": "Server={YourServerName};Database={YourDatabaseName};Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "{YourSecretKeyHere}",
    "Issuer": "TodoApi",
    "Audience": "TodoApiClient"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
